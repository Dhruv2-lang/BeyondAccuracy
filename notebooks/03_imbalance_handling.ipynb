   ],
   "source": [
    "rus = RandomUnderSampler(random_state=42)\n",
    "X_train_rus, y_train_rus = rus.fit_resample(X_train, y_train)\n",
    "\n",
    "print(\"After undersampling:\", pd.Series(y_train_rus).value_counts().to_dict())\n",
    "\n",
    "xgb_rus = xgb.XGBClassifier(eval_metric='logloss', random_state=42)\n",
    "xgb_rus.fit(X_train_rus, y_train_rus)\n",
    "y_pred_rus = xgb_rus.predict(X_test)\n",
    "\n",
    "print(\"\\n--- XGBoost with undersampling ---\")\n",
    "print(\"Accuracy:\", accuracy_score(y_test, y_pred_rus))\n",
    "print(confusion_matrix(y_test, y_pred_rus))\n",
    "print(classification_report(y_test, y_pred_rus))"
   ]
  },
